// server/prisma/schema.prisma
// ─────────────────────────────────────────────────────────────────────────────
// GTM Back-Office — Prisma Schema v2 (Post-Review)
// PostgreSQL 16 · Prisma 5
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm]  // enables GIN trigram indexes for fast ILIKE search
}

// ─────────────────────────────────────────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN  // full CRUD + user management + audit log access
  OPERATOR     // CRUD on products; read-only on orders/contracts
  VIEWER       // read-only on all panels
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String     // bcrypt hash — plaintext NEVER stored
  role         UserRole   @default(OPERATOR)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  sessions     Session[]
  auditLogs    AuditLog[]

  @@index([email])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt]) // scanned by nightly pruning cron
}

// ─────────────────────────────────────────────────────────────────────────────
// AUDIT LOG
// Captures all SUPER_ADMIN write actions. Immutable from application code.
// ─────────────────────────────────────────────────────────────────────────────

enum AuditAction {
  CREATE
  UPDATE
  SOFT_DELETE
  ROLE_CHANGE
  LOGIN
  LOGOUT
}

model AuditLog {
  id           String      @id @default(cuid())
  actorId      String
  actor        User        @relation(fields: [actorId], references: [id])
  action       AuditAction
  resourceType String      // e.g. "Product", "Contract", "User"
  resourceId   String      // the affected record's PK
  previousJson Json?       // snapshot before change (null on CREATE)
  nextJson     Json?       // snapshot after change (null on SOFT_DELETE)
  ip           String?
  createdAt    DateTime    @default(now())

  @@index([actorId])
  @@index([resourceType, resourceId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// PRODUCT REGISTRY
// Maps: CatalogData.js → { id, name, category, subCategory, price, image,
//                          localImageName, standardColors[] }
// ─────────────────────────────────────────────────────────────────────────────

enum ProductCategory {
  APPAREL
  UNIFORM_WORKWEAR
  SPORTSWEAR
}

model Product {
  id             Int             @id @default(autoincrement())
  sku            String          @unique @default(cuid()) // public-facing opaque ref
  name           String
  category       ProductCategory
  subCategory    String
  priceUsd       Decimal?        @db.Decimal(10, 2)       // numeric — not "$12.99" string
  imageUrl       String?
  localImageName String?
  isActive       Boolean         @default(true)            // soft-delete flag
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  colors         ProductColor[]
  orderItems     OrderItem[]

  @@index([category])
  @@index([isActive])
  // GIN trigram indexes added via post-migration SQL in prisma/migrations/:
  //   CREATE INDEX product_name_trgm_idx ON "Product" USING gin (name gin_trgm_ops);
  //   CREATE INDEX product_sub_trgm_idx  ON "Product" USING gin ("subCategory" gin_trgm_ops);
}

model ProductColor {
  id        Int     @id @default(autoincrement())
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  colorName String

  @@unique([productId, colorName])
  @@index([productId])
}

// ─────────────────────────────────────────────────────────────────────────────
// RETAIL SALES LOG
// Maps: MOCK_RETAIL → { id, client, email, phone, qty, status }
//
// ID Strategy (FIX #3): surrogate-key pattern
//   id        → cuid() internal PK — used in all FK relations
//   displayId → "ORD-XXXX" human-readable — generated via Postgres sequence
//
// totalQty (FIX #8): intentionally omitted.
//   Computed on read: items.reduce((sum, i) => sum + i.qty, 0)
//   Prisma issues exactly 2 SQL statements for include: { items: { select: { qty } } }
//   This avoids a denormalized field going stale on item amendments.
// ─────────────────────────────────────────────────────────────────────────────

enum OrderStatus {
  PENDING
  PROCESSING
  DISPATCHED
  CANCELLED
}

enum SampleStatus {
  NONE
  PENDING
  IN_PRODUCTION
  DISPATCHED
  APPROVED
  REJECTED
}

model Client {
  id          String        @id @default(cuid())
  fullName    String
  companyName String?       // buyer's company — populated by public /quote endpoint
  email       String        @unique
  phone       String?
  createdAt   DateTime      @default(now())
  orders      RetailOrder[]

  @@index([email])
}

model RetailOrder {
  id             String       @id @default(cuid())           // internal PK
  displayId      String       @unique                         // e.g. "ORD-0091" — server-generated
  clientId       String
  client         Client       @relation(fields: [clientId], references: [id])
  status         OrderStatus  @default(PENDING)
  sampleStatus   SampleStatus @default(NONE)
  deliveryWindow String?      // buyer's requested delivery window — from public /quote
  placedAt       DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  items          OrderItem[]

  @@index([status])
  @@index([sampleStatus])
  @@index([clientId])
  @@index([placedAt])
  @@index([displayId])
}

model OrderItem {
  id        Int         @id @default(autoincrement())
  orderId   String
  order     RetailOrder @relation(fields: [orderId], references: [id])
  productId Int
  // onDelete: Restrict (default) — correct. Prevents hard-deleting a product
  // that has order history. Soft-delete (isActive=false) is used instead.
  product   Product     @relation(fields: [productId], references: [id])
  colorName String?     // buyer's selected finish, e.g. "Navy Blue" — nullable, set by the public quote endpoint
  qty       Int
  unitPrice Decimal?    @db.Decimal(10, 2)

  @@index([orderId])
  @@index([productId])
}

// ─────────────────────────────────────────────────────────────────────────────
// CORPORATE CONTRACTS
// Maps: MOCK_CONTRACTS → { id, company, rep, window, count, specs }
//
// ID Strategy: same surrogate-key pattern as RetailOrder
//   id        → cuid() internal PK
//   displayId → "RFQ-XXXXXX" — generated via Postgres sequence
// ─────────────────────────────────────────────────────────────────────────────

enum ContractStatus {
  RFQ_RECEIVED   // initial state
  COSTING        // pricing being prepared
  APPROVED       // go-ahead given
  IN_PRODUCTION
  COMPLETED
  CANCELLED
}

model Contract {
  id             String         @id @default(cuid())   // internal PK
  displayId      String         @unique                  // e.g. "RFQ-192041"
  companyName    String
  repEmail       String
  deliveryWindow String
  unitCount      Int
  specsRaw       String         @db.Text
  status         ContractStatus @default(RFQ_RECEIVED)
  isActive       Boolean        @default(true)           // soft-delete flag
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([status])
  @@index([isActive])
  @@index([companyName])
  @@index([createdAt])
}

