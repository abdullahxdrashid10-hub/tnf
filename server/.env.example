# GTM Server — Environment Variables Template
# Copy this file to .env and fill in real values.
# .env is gitignored. NEVER commit secrets to source control.

# ── Database ──────────────────────────────────────────────────────────────────
# Railway: copy from the "Connect" tab on your Postgres service.
# Supabase: Settings → Database → Connection String (transaction mode, port 6543).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/gtm_admin?schema=public"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development                   # "development" | "production"
FRONTEND_ORIGIN=http://localhost:5173  # Exact origin — no trailing slash

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=REPLACE_WITH_256_BIT_SECRET
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Cookie ────────────────────────────────────────────────────────────────────
# Must be a different secret from JWT_SECRET.
COOKIE_SECRET=REPLACE_WITH_ANOTHER_256_BIT_SECRET
# SameSite policy is derived from NODE_ENV in config.ts:
#   development → "Lax"   (localhost, no HTTPS required)
#   production  → "None"  (cross-origin; HTTPS mandatory on both ends)

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Optional. Set to a Redis URL to persist rate-limit counters across server
# restarts. Leave empty to use in-memory store (fine for single-instance dev).
REDIS_URL=
